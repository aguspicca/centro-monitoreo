# Centro de Monitoreo - Variables de entorno
# Copia este archivo como .env.local y completa los valores

# Opcional: configuración pre-cargada de Jira
# (también se puede configurar desde la interfaz)
NEXT_PUBLIC_JIRA_URL=https://tu-empresa.atlassian.net
NEXT_PUBLIC_JIRA_EMAIL=tu-email@empresa.com

# IMPORTANTE: El API Token nunca debe exponerse públicamente.
# Usar NEXT_PUBLIC_ solo para demo. En producción usar variable sin prefijo
# y pasar las requests a través del API Route del backend.
JIRA_API_TOKEN=tu-api-token-aqui

# SLA por defecto (días) cuando un ticket no tiene Due Date
NEXT_PUBLIC_SLA_DEFAULT_DAYS=5

# Intervalo de refresh en milisegundos (default: 300000 = 5 minutos)
NEXT_PUBLIC_REFRESH_INTERVAL=300000
